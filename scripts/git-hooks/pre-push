#!/usr/bin/env bash
# Pre-push hook — DISABLED for now.
#
# Auto-running the doc-update flow on every push to main was causing
# more friction than value during the active feature-folder refactor:
# every doc regen amended large diffs into commits, which made history
# noisy and several times accidentally tracked agent worktree dirs as
# gitlinks. Re-enable when the refactor settles and we want docs to
# stay perfectly in sync with code on every push.
#
# To re-enable: uncomment the doc-update block below. The
# scripts/update-docs.sh script is still in place — you can run it
# manually anytime via `bun run docs:update`.
#
# Install via: `bun run install-hooks` (symlinks this file into .git/hooks/)
set -euo pipefail

# Disabled — exit immediately so pushes go through untouched.
exit 0

