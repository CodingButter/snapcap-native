{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "rewriteRelativeImportExtensions": true
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "vendor", "docs", "scripts", "**/*.test.ts"]
}
