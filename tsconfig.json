{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["bun"],

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,

    "outDir": "./dist"
  },
  "include": ["src/**/*", "scripts/**/*"],
  // Dev probe scripts — one-off investigation tools, not part of the SDK
  // contract. Updated as needed when next used; type-checking them blocks
  // the canonical paths (smoke, smoke-multi-instance, mint-attestation).
  "exclude": [
    "dist", "node_modules", "vendor", "docs",
    "scripts/probe-*.ts",
    "scripts/capture-*.ts",
    "scripts/test-bundle-auth.ts",
    "scripts/check-friend-state.ts",
    "scripts/send-friend-request.ts",
    "scripts/playwright-login.ts",
    "scripts/verify-account.ts"
  ]
}
