{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["bun"],

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,

    "outDir": "./dist"
  },
  "include": ["src/**/*", "scripts/**/*", "tests/**/*"],
  // The personal probe/test scripts that USED to live in scripts/ have
  // moved to .tmp/scripts/ (gitignored). The exclude list below is now
  // historical — most of those files no longer exist in scripts/. Kept
  // as defensive entries in case any one-off script gets reintroduced.
  "exclude": [
    "dist", "node_modules", "vendor", "docs",
    "scripts/probe-*.ts",
    "scripts/capture-*.ts",
    "scripts/test-bundle-auth.ts",
    "scripts/check-friend-state.ts",
    "scripts/send-friend-request.ts",
    "scripts/playwright-login.ts",
    "scripts/verify-account.ts"
  ]
}
